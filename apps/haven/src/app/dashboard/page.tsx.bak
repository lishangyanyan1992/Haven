import { AppShell } from "@/components/app/app-shell";
import { Badge } from "@/components/ui/badge";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { getSnapshot } from "@/lib/repositories/case-compass";

export default async function DashboardPage() {
  const { profile, dashboard } = await getSnapshot();

  return (
    <AppShell
      activePath="/dashboard"
      title="Your Haven dashboard"
      description="A personalized starting point for high-stakes immigration planning moments."
    >
      <section className="grid gap-4 xl:grid-cols-[1.2fr_0.8fr]">
        <Card className="bg-[linear-gradient(145deg,rgba(20,71,65,0.98)_0%,rgba(26,93,84,0.94)_54%,rgba(38,120,108,0.9)_100%)] text-white">
          <CardHeader className="items-start">
            <div>
              <p className="text-xs uppercase tracking-[0.22em] text-white/60">Profile pulse</p>
              <CardTitle className="mt-3 text-[32px] text-white md:text-[40px]">You are currently in a {profile.visaType} + {profile.preferenceCategory} path.</CardTitle>
            </div>
          </CardHeader>
          <CardContent className="grid gap-5 md:grid-cols-3">
            <div className="rounded-[24px] bg-white/10 p-5 backdrop-blur">
              <p className="text-xs uppercase tracking-[0.18em] text-white/60">Readiness</p>
              <p className="mt-3 text-3xl font-semibold capitalize">{dashboard.signals.layoffReadinessScore}</p>
              <p className="mt-3 text-sm text-white/72">Updated from your immigration profile, I-140 state, and spouse path.</p>
            </div>
            <div className="rounded-[24px] bg-white/10 p-5 backdrop-blur">
              <p className="text-xs uppercase tracking-[0.18em] text-white/60">GC estimate</p>
              <p className="mt-3 text-3xl font-semibold">{dashboard.signals.estimatedGreenCardDateRange ?? "Pending"}</p>
              <p className="mt-3 text-sm text-white/72">Directional only. Haven should keep recalculating as bulletins move.</p>
            </div>
            <div className="rounded-[24px] bg-white/10 p-5 backdrop-blur">
              <p className="text-xs uppercase tracking-[0.18em] text-white/60">Community signal</p>
              <p className="mt-3 text-lg font-semibold leading-7">{dashboard.communityMatchesLabel}</p>
              <p className="mt-3 text-sm text-white/72">{profile.countryOfBirth} born · concern areas: {profile.topConcerns.join(", ")}</p>
            </div>
          </CardContent>
        </Card>
        <Card className="bg-[linear-gradient(180deg,rgba(255,255,255,0.92)_0%,rgba(246,242,235,0.88)_100%)]">
          <CardHeader>
            <CardTitle>Readiness reasoning</CardTitle>
          </CardHeader>
          <CardContent className="space-y-3">
            {dashboard.signals.layoffReadinessReasoning.map((item) => (
              <div key={item} className="rounded-[22px] border border-[rgba(121,102,84,0.12)] bg-white/70 px-4 py-4 text-sm text-slate-700">
                {item}
              </div>
            ))}
          </CardContent>
        </Card>
      </section>
      <section className="mt-6 grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
        <Card>
          <CardHeader>
            <CardTitle>Next actions</CardTitle>
          </CardHeader>
          <CardContent className="space-y-5">
            {dashboard.nextActions.map((item) => (
              <div key={item} className="rounded-[24px] bg-[linear-gradient(180deg,rgba(244,248,246,1)_0%,rgba(236,244,241,1)_100%)] px-5 py-5 text-sm shadow-[inset_0_1px_0_rgba(255,255,255,0.7)]">
                <p className="text-xs uppercase tracking-[0.18em] text-[rgba(32,94,83,0.68)]">Recommended next move</p>
                <p className="mt-3 text-[15px] leading-6 text-slate-800">{item}</p>
              </div>
            ))}
          </CardContent>
        </Card>
        <Card>
          <CardHeader>
            <CardTitle>Timeline highlights</CardTitle>
          </CardHeader>
          <CardContent className="space-y-4">
            {dashboard.timelineHighlights.map((event) => (
              <div key={event.id} className="rounded-[24px] border border-[rgba(121,102,84,0.12)] px-5 py-5">
                <div className="flex items-center justify-between gap-3">
                  <p className="font-medium text-slate-900">{event.title}</p>
                  <Badge>{event.group}</Badge>
                </div>
                <p className="mt-2 text-sm text-muted-foreground">{event.dateLabel}</p>
                <p className="mt-3 text-sm leading-6 text-slate-700">{event.nextAction}</p>
              </div>
            ))}
          </CardContent>
        </Card>
      </section>
    </AppShell>
  );
}
